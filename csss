<!DOCTYPE html>
<html lang="bn">

<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Our Love Story ❤️</title>

<script src="https://cdn.tailwindcss.com"></script>

<style>

body{
margin:0;
overflow-x:hidden;
font-family:sans-serif;
color:white;
background:linear-gradient(#87ceeb,#7ed957);
transition:1s;
}

/* night mode */

.night{
background:linear-gradient(#020024,#090979,#000000);
}

/* sun */

.sun{
position:absolute;
top:80px;
right:80px;
width:120px;
height:120px;
background:yellow;
border-radius:50%;
box-shadow:0 0 80px yellow;
}

/* stars */

.star{
position:absolute;
color:white;
font-size:8px;
animation:twinkle 2s infinite alternate;
}

@keyframes twinkle{
0%{opacity:.3}
100%{opacity:1}
}

/* birds */

.bird{
position:absolute;
font-size:35px;
animation:fly 18s linear infinite;
}

@keyframes fly{
0%{left:-50px}
100%{left:110%}
}

/* trees */

.tree{
position:absolute;
bottom:0;
font-size:120px;
animation:wind 4s infinite alternate;
}

@keyframes wind{
0%{transform:rotate(0deg)}
100%{transform:rotate(2deg)}
}

/* flowers */

.flower{
position:absolute;
bottom:0;
font-size:40px;
animation:grow 2s forwards;
}

@keyframes grow{
0%{transform:scale(0)}
100%{transform:scale(1)}
}

/* hearts */

.heart{
position:fixed;
bottom:-20px;
font-size:25px;
animation:hearts 6s linear infinite;
}

@keyframes hearts{
0%{transform:translateY(0)}
100%{transform:translateY(-110vh)}
}

/* roses */

.rose{
position:absolute;
bottom:0;
font-size:45px;
animation:grow 3s forwards;
}

/* button */

button{
background:#ff4da6;
padding:12px 25px;
border-radius:30px;
font-size:18px;
}

button:hover{
background:#ff1a8c;
}

/* sections */

.memories{
background:linear-gradient(#ff9acb,#ff4da6);
}

.proposal{
background:linear-gradient(#ff4da6,#b30059);
}

.person{
width:120px;
height:120px;
border-radius:50%;
border:4px solid white;
object-fit:cover;
}

.romantic{
font-family:cursive;
}

.glow{
text-shadow:0 0 20px #ff4da6;
}

.toggle{
position:fixed;
top:20px;
right:20px;
z-index:999;
}

</style>

</head>

<body>

<!-- romantic music -->

<audio autoplay loop>
<source src="https://www.bensound.com/bensound-music/bensound-romantic.mp3">
</audio>

<!-- birds sound -->

<audio autoplay loop>
<source src="https://www.soundjay.com/nature/birds-1.mp3">
</audio>

<!-- night button -->

<button class="toggle" onclick="toggleNight()">🌙 Night</button>

<!-- sun -->

<div class="sun"></div>

<!-- trees -->

<div class="tree" style="left:0">🌳</div>
<div class="tree" style="left:85%">🌳</div>

<!-- birds -->

<div class="bird" style="top:100px">🐦</div>
<div class="bird" style="top:150px;animation-delay:6s">🕊️</div>
<div class="bird" style="top:200px;animation-delay:10s">🐦</div>

<!-- hero -->

<section class="text-center h-screen flex flex-col justify-center items-center">

<h1 class="text-6xl romantic glow mb-10">
Hello Mohona ❤️
</h1>

<button onclick="startJourney()">Start Our Journey</button>

<div id="flowerField" class="relative w-full max-w-xl h-40 mt-10"></div>

</section>


<!-- memories -->

<section class="py-20 text-center memories">

<h2 class="text-5xl romantic glow mb-10">
Memories 📸
</h2>

<div class="grid grid-cols-2 md:grid-cols-4 gap-5 max-w-5xl mx-auto">

<img src="images/pic1.jpg">
<img src="images/pic2.jpg">
<img src="images/pic3.jpg">
<img src="images/pic4.jpg">

</div>

</section>


<!-- videos -->

<section class="text-center py-20">

<h2 class="text-5xl romantic glow mb-10">
Our Videos 🎥
</h2>

<button onclick="showVideos()">Play Videos</button>

<div id="videos" class="hidden grid md:grid-cols-3 gap-10 max-w-5xl mx-auto mt-10">

<video controls width="300">
<source src="images/video1.mp4">
</video>

<video controls width="300">
<source src="images/video2.mp4">
</video>

<video controls width="300">
<source src="images/video3.mp4">
</video>

</div>

</section>


<!-- rose garden -->

<section class="text-center py-20">

<h2 class="text-5xl romantic glow mb-10">
Rose Garden 🌹
</h2>

<button onclick="growRoses()">Grow Roses</button>

<div id="roseGarden" class="relative h-40 mt-10"></div>

</section>


<!-- proposal -->

<section class="text-center py-20 proposal">

<h2 class="text-5xl romantic glow mb-10">
Proposal 💍
</h2>

<div onclick="startProposal()" style="font-size:80px;cursor:pointer">
💍
</div>

<div id="proposalBox" style="display:none;margin-top:40px">

<div class="flex justify-center gap-20 items-center">

<div>
<img src="images/me.jpg" class="person">
<p>আমি ❤️</p>
</div>

<div>
<img src="images/mohona.jpg" class="person">
<p>Mohona ❤️</p>
</div>

</div>

<p class="text-3xl mt-10">
Mohona ❤️ তুমি কি আমাকে বিয়ে করতে চাও?
</p>

<button onclick="ringAnimation()" class="mt-5">
Yes ❤️
</button>

<p id="finalMsg" class="text-4xl mt-10 hidden">
💍 Thank You Mohona ❤️ <br>
I Love You
</p>

</div>

</section>


<script>

/* night mode */

function toggleNight(){

document.body.classList.toggle("night")

createStars()

}

/* stars */

function createStars(){

if(!document.body.classList.contains("night")) return

for(let i=0;i<80;i++){

let star=document.createElement("div")

star.className="star"

star.innerHTML="✦"

star.style.top=Math.random()*100+"%"

star.style.left=Math.random()*100+"%"

document.body.appendChild(star)

}

}

/* flower animation */

function startJourney(){

let field=document.getElementById("flowerField")

field.innerHTML=""

for(let i=0;i<20;i++){

let flower=document.createElement("div")

flower.className="flower"

flower.innerHTML=["🌸","🌼","🌷","🌻"][Math.floor(Math.random()*4)]

flower.style.left=Math.random()*90+"%"

field.appendChild(flower)

}

/* hearts */

setInterval(()=>{

let heart=document.createElement("div")

heart.className="heart"

heart.innerHTML="❤️"

heart.style.left=Math.random()*100+"%"

document.body.appendChild(heart)

setTimeout(()=>heart.remove(),6000)

},600)

}

/* videos */

function showVideos(){

document.getElementById("videos").classList.remove("hidden")

}

/* roses */

function growRoses(){

let garden=document.getElementById("roseGarden")

garden.innerHTML=""

for(let i=0;i<15;i++){

let rose=document.createElement("div")

rose.className="rose"

rose.innerHTML="🌹"

rose.style.left=Math.random()*90+"%"

garden.appendChild(rose)

}

}

/* proposal */

function startProposal(){

document.getElementById("proposalBox").style.display="block"

}

function ringAnimation(){

document.getElementById("finalMsg").classList.remove("hidden")

}

</script>

</body>

</html>//